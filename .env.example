# ── Admin / Cron Secret ───────────────────────────────────────────────────────
# Required to call destructive admin endpoints:
#   POST /api/admin/reset-locations
#   GET  /api/reports/location-history  (machine access)
#   POST /admin/wipe
#   GET/POST /admin/fix-periods
#
# Set in Render dashboard: service → Environment → Add environment variable
# Name:  CRON_SECRET
# Value: a long random string, e.g. output of:
#        python3 -c "import secrets; print(secrets.token_hex(32))"
#
# Pass as header in curl:  -H "X-Admin-Secret: <value>"
# Or as query param:       ?key=<value>
CRON_SECRET=replace-with-a-long-random-secret

